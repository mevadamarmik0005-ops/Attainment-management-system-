PORT=4000
JWT_SECRET=change-this-to-a-long-random-string

# ---- Database driver: choose ONE ----
# "json"  (default) -> data/attainment.json on this computer only, zero setup
# "mongo"            -> a real shared database reachable from any computer
DB_DRIVER=json

# Only used when DB_DRIVER=json
DATA_DIR=./data

# Only used when DB_DRIVER=mongo — get a free connection string at
# https://www.mongodb.com/cloud/atlas (see src/db/mongo.js for step-by-step notes)
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
# MONGODB_DB=attainment
